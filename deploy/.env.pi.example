# Copy to deploy/.env.pi and adjust before deploying.
# cp deploy/.env.pi.example deploy/.env.pi

# --- SSH / deploy script ---
PI_HOST=piserver
PI_USER=kbo
# Use absolute path (~ expands to your Mac home when sourced locally)
PI_REMOTE_DIR=/home/kbo/athletiq
# SSH password (deploy/.env.pi is gitignored). Requires: brew install hudochenkov/sshpass/sshpass
PI_SSH_PASSWORD=your-pi-password
# Optional: use key auth instead of password (leave PI_SSH_PASSWORD empty)
# PI_SSH_IDENTITY_FILE=~/.ssh/id_ed25519
COMPOSE_PROJECT_NAME=athletiq

# --- App database ---
POSTGRES_DB=athletiq
POSTGRES_USER=athletiq
POSTGRES_PASSWORD=change-me-strong-password

# --- HAPI FHIR database (defaults match AthletIQ-Backend/docker-compose.yml) ---
HAPI_DB_PASSWORD=hapi_secret

# --- API ---
ASPNETCORE_ENVIRONMENT=Production
JWT_SECRET=change-me-at-least-32-characters-long-secret
JWT_ISSUER=AthletIQ
JWT_AUDIENCE=AthletIQ
JWT_EXPIRATION_MINUTES=60
SEED_ON_STARTUP=false

# --- Ports exposed on the Pi host ---
FRONTEND_PORT=5000
API_PORT=8082
LANDINGPAGE_PORT=8081

# --- Frontend build ---
NEXT_PUBLIC_API_BASE_URL=same-origin
